# ── Railway PostgreSQL (injected automatically by Railway) ─────────────────────
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# ── Supabase — identity validation only (no DB, no Storage) ──────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ── Railway Volume — document storage ─────────────────────────────────────────
DOCUMENTS_PATH=/data/documents

# ── Internal Railway service URLs (private network — no public egress cost) ───
DOC_AGENT_URL=http://pa-doc-agent.railway.internal:8000
SUMMARY_AGENT_URL=http://pa-summary-agent.railway.internal:8001

# ── Shared secret for internal Railway service calls ─────────────────────────
AGENT_API_KEY=change-me-in-production

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-app.netlify.app
