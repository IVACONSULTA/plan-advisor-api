# ── PostgreSQL (Railway injects DATABASE_URL in production) ───────────────────
# Local (Docker example from README):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/planadvisor
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# ── Supabase — identity validation only (no DB, no Storage) ──────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Optional: sync Auth → users_profile (scripts/sync-supabase-auth-users-to-users-profile.js).
# service_role is secret — never put it in frontend builds or commit real keys.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Railway Volume — document storage ─────────────────────────────────────────
DOCUMENTS_PATH=/data/documents

# ── Internal Railway service URLs (private network — same Railway project only) ─
# *.railway.internal resolves ONLY from services running on Railway. For local
# API dev, use each service's public URL instead, e.g.
#   SUMMARY_AGENT_URL=https://pa-summary-agent-production.up.railway.app
DOC_AGENT_URL=http://pa-doc-agent.railway.internal:8000
SUMMARY_AGENT_URL=http://pa-summary-agent.railway.internal:8001

# ── Shared secret for internal Railway service calls ─────────────────────────
AGENT_API_KEY=change-me-in-production

# ── Public API gate (required when NODE_ENV=production) ─────────────────────
# Send on every request except GET /health and GET /live:
#   X-API-Key: <same value>
PA_PLAN_API_KEY=change-me-client-api-key

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-app.netlify.app

# Trust N reverse-proxy hops for X-Forwarded-For (default in code is 1 — fine for Railway)
# TRUST_PROXY_COUNT=1
