# ── PostgreSQL (Railway injects DATABASE_URL in production) ───────────────────
# Local (Docker example from README):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/planadvisor
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# ── Supabase — identity validation only (no DB, no Storage) ──────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Optional: sync Auth → users_profile (scripts/sync-supabase-auth-users-to-users-profile.js).
# service_role is secret — never put it in frontend builds or commit real keys.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Document storage ──────────────────────────────────────────────────────────
# Railway S3-compatible bucket (preferred — files persist across restarts):
# Set these in the Railway service Variables tab (copy from the bucket's Credentials tab).
# S3_BUCKET_NAME=assembled-carton-xxxxxxxx   ← bucket name
# AWS_ENDPOINT_URL=https://t3.storageapi.dev ← Railway bucket endpoint
# AWS_DEFAULT_REGION=auto
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
#
# When any of S3_BUCKET / AWS_S3_BUCKET / S3_BUCKET_NAME / AWS_S3_BUCKET_NAME is set,
# storage automatically switches to S3 mode. No STORAGE_DRIVER needed.
#
# Railway Volume fallback (ephemeral — files lost on restart unless volume is attached):
DOCUMENTS_PATH=/data/documents
# Local API dev (no Railway volume): e.g. DOCUMENTS_PATH=./data/documents (relative to PlanAdvisorAPI cwd)

# ── Internal Railway service URLs (private network — same Railway project only) ─
# *.railway.internal resolves ONLY from services running on Railway. For local
# API dev, use each service's public URL instead, e.g.
#   SUMMARY_AGENT_URL=https://pa-summary-agent-production.up.railway.app
DOC_AGENT_URL=http://pa-doc-agent.railway.internal:8000
# Optional: max wait for document agent /analyze (ms). Default 290000 (~4.8 min). Raise if Crew runs longer; if the admin UI uses Netlify, keep below the SSR function limit in netlify.toml.
# DOC_AGENT_TIMEOUT_MS=290000
# Optional: log document agent JSON responses to API stdout (Railway logs). Set false if too noisy.
# DOC_AGENT_LOG_RESPONSE=true
# DOC_AGENT_LOG_RESPONSE_MAX_CHARS=100000
SUMMARY_AGENT_URL=http://pa-summary-agent.railway.internal:8001

# ── Shared secret for internal Railway service calls ─────────────────────────
# Shared default for document agent. Summary agent can use the same or its own:
AGENT_API_KEY=change-me-in-production
# If the summary service uses a different X-API-Key secret than the doc agent, set this
# (Plan API uses SUMMARY_AGENT_API_KEY for /generate-summary when present — it overrides AGENT_API_KEY).
# SUMMARY_AGENT_API_KEY=change-me-summary-only

# ── Public API gate (required when NODE_ENV=production) ─────────────────────
# Send on every request except GET /health and GET /live:
#   X-API-Key: <same value>
PA_PLAN_API_KEY=change-me-client-api-key

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://your-app.netlify.app

# Trust N reverse-proxy hops for X-Forwarded-For (default in code is 1 — fine for Railway)
# TRUST_PROXY_COUNT=1
