  "item": [
    {
      "name": "0. Supabase — login (sets access_token)",
      "item": [
        {
          "name": "POST password sign-in → saves access_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const d = pm.response.json();",
                  "  if (d.access_token) {",
                  "    pm.environment.set('access_token', d.access_token);",
                  "    pm.test('access_token saved to Environment', () => true);",
                  "    console.log('OK: access_token stored (' + d.access_token.length + ' chars)');",
                  "  } else {",
                  "    console.log('No access_token in body:', d);",
                  "  }",
                  "} catch (e) { console.log(e); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "apikey",
                "value": "{{supabase_anon_key}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{supabase_email}}\",\n  \"password\": \"{{supabase_password}}\"\n}\n"
            },
            "url": "{{supabase_url}}/auth/v1/token?grant_type=password",
            "description": "Ensure Environment has: supabase_url (e.g. https://xxxx.supabase.co), supabase_anon_key, supabase_email, supabase_password. No trailing slash on supabase_url."
          }
        }
      ]
    },
