## 3. Guardrail Architecture

### Mandatory Two-Layer Guardrail

```python
# guardrails/copyright_pipeline.py
"""
Master copyright compliance pipeline.
Must run before every LLM inference call that uses third-party documents.
"""
from guardrails.copyright_checker import CopyrightChecker
from guardrails.output_validator import OutputCopyrightValidator

class CopyrightCompliancePipeline:
    """
    Two-layer copyright guardrail:
    Layer 1 (Pre-LLM):  Classify documents, block opted-out content
    Layer 2 (Post-LLM): Validate output contains no verbatim RESTRICTED text
    """

    def __init__(self):
        self.checker = CopyrightChecker()
        self.validator = OutputCopyrightValidator()

    # --- LAYER 1: Pre-LLM ---

    def pre_llm_check(self, documents: list) -> dict:
        """
        Run before any LLM inference call.
        Returns processable documents and blocks opted-out ones.
        """
        all_clear, results = self.checker.check_documents(documents)

        blocked = [r for r in results if r['status'] == 'blocked']
        if blocked:
            # Hard stop — do not call LLM at all if any doc is blocked
            raise CopyrightViolationError(
                blocked_docs=[d['filename'] for d in blocked],
                reasons=[d['reason'] for d in blocked],
                http_status=451
            )

        # Return processable docs with their constraint level
        processable = [
            {
                **doc,
                'copyright_status': next(
                    r['status'] for r in results if r['filename'] == doc['filename']
                )
            }
            for doc in documents
        ]

        return {
            'processable_documents': processable,
            'copyright_results': results,
            'all_clear': all_clear
        }

    def build_system_prompt_constraints(self, copyright_results: list) -> str:
        """
        Build copyright constraint instructions for the LLM system prompt.
        """
        has_restricted = any(r['status'] == 'restricted' for r in copyright_results)

        constraints = [
            "CITATION REQUIREMENT: Every extracted rule or plan must include the source document name.",
        ]

        if has_restricted:
            constraints.append(
                "PARAPHRASE REQUIREMENT: Documents marked as 'restricted' have reproduction "
                "restrictions under InfoSoc Directive 2001/29/EC. Do NOT reproduce verbatim "
                "text from these documents. Paraphrase all excerpts. Extract factual "
                "information only (prices, thresholds, transaction counts)."
            )

        return "\n".join(constraints)

    # --- LAYER 2: Post-LLM ---

    def post_llm_check(self, output: dict, copyright_results: list) -> dict:
        """
        Run after LLM inference.
        Validates output complies with copyright constraints.
        """
        restricted_docs = [
            r for r in copyright_results if r['status'] == 'restricted'
        ]

        # Check that no rules/plans have status='active' (also EU AI Act check)
        for item in output.get('rules', []) + output.get('plans', []):
            if item.get('status') == 'active':
                raise ComplianceError(
                    "Output validation failed: item has status='active'. "
                    "All proposed items must have status='pending'."
                )
            item['status'] = 'pending'

        # Validate source_excerpts for RESTRICTED documents
        violations = self.validator.check_verbatim_excerpts(
            output, restricted_docs
        )
        if violations:
            raise CopyrightViolationError(
                violations=violations,
                message="Output contains verbatim text from RESTRICTED documents."
            )

        return output
```

