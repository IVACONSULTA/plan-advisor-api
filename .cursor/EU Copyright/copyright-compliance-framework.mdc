## 5. Testing and Validation

### Pre-Deployment Testing

```python
class CopyrightComplianceTestSuite:
    """Test suite for copyright guardrail validation."""

    def test_ai_optout_blocking(self):
        """Verify documents with AI opt-out patterns are blocked (HTTP 451)."""
        # AFNOR-style French opt-out
        doc_afnor = {
            'filename': 'afnor_test.pdf',
            'text': (
                "AFNOR s'oppose expressément à l'utilisation de ses publications pour "
                "l'entraînement ou l'intégration dans des systèmes d'intelligence artificielle."
            )
        }
        all_clear, results = CopyrightChecker().check_documents([doc_afnor])
        assert not all_clear
        assert results[0]['status'] == 'blocked'
        assert results[0]['restriction_type'] == 'ai_optout'

    def test_restricted_paraphrase_enforcement(self):
        """Verify RESTRICTED documents get paraphrase instruction."""
        doc_restricted = {
            'filename': 'pricing.pdf',
            'text': '© 2024 All Rights Reserved. Annual fee: €1,200 for 5,000 transactions.'
        }
        all_clear, results = CopyrightChecker().check_documents([doc_restricted])
        assert results[0]['status'] == 'restricted'
        # Verify paraphrase action is set
        assert 'paraphrased' in results[0]['action'].lower()

    def test_clear_document_citation(self):
        """Verify CLEAR documents still require citation."""
        doc_clear = {
            'filename': 'open_guide.pdf',
            'text': 'Open Government Licence v3.0. Annual fee: €800 for 3,000 transactions.'
        }
        _, results = CopyrightChecker().check_documents([doc_clear])
        assert results[0]['status'] == 'clear'

    def test_verbatim_output_rejection(self):
        """Verify post-LLM check rejects verbatim excerpts from RESTRICTED docs."""
        verbatim_output = {
            'rules': [{
                'source_excerpt': 'All rights reserved. No part of this document may be reproduced.',
                'status': 'pending'
            }]
        }
        restricted_results = [{'status': 'restricted', 'filename': 'test.pdf'}]
        # Should raise CopyrightViolationError
        with pytest.raises(CopyrightViolationError):
            CopyrightCompliancePipeline().post_llm_check(
                verbatim_output, restricted_results
            )
```

