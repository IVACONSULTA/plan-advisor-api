## 📥 Copyright at Inference Time (RAG and Document Analysis)

Inference-time use (sending document text to an LLM API) is **not training** — but it still involves:

1. **Temporary reproduction** of the document text in the API request (Art. 5(1) transient copy)
2. **Potential output reproduction** if the LLM reproduces verbatim text in its response

### Rules for Inference-Time Use

```python
class InferenceTimeCopyrightGuard:
    """
    Implements copyright compliance for LLM inference calls
    using third-party documents as context (RAG, document analysis).
    """

    def prepare_context_for_inference(
        self, documents: list, copyright_results: list
    ) -> dict:
        """
        Prepare documents for LLM inference with copyright constraints.
        Only CLEAR and RESTRICTED documents may be sent to the LLM.
        BLOCKED documents must never be included.
        """
        context_docs = []
        excluded_docs = []

        for doc, result in zip(documents, copyright_results):
            if result['status'] == 'blocked':
                # NEVER send blocked docs to LLM — EU AI Act Art. 53(1)(c)
                excluded_docs.append({
                    'filename': doc['filename'],
                    'reason': 'AI opt-out detected — excluded from inference',
                    'legal_basis': 'DSM Directive Art. 4 / EU AI Act Art. 53(1)(c)'
                })
                continue

            context_docs.append({
                'text': doc['text'],
                'filename': doc['filename'],
                'copyright_status': result['status'],
                # Add paraphrase instruction for restricted docs
                'processing_instruction': (
                    'PARAPHRASE_ONLY — do not reproduce verbatim text'
                    if result['status'] == 'restricted'
                    else 'CITE_SOURCE — include document reference in output'
                )
            })

        return {
            'context_documents': context_docs,
            'excluded_documents': excluded_docs,
            'inference_permitted': len(context_docs) > 0
        }

    def validate_inference_output(self, output: str, restricted_docs: list) -> dict:
        """
        Post-inference validation: check output does not contain
        verbatim excerpts from RESTRICTED documents.
        Based on Infopaq doctrine (CJEU C-5/08) — 11 words threshold.
        """
        violations = []

        for doc in restricted_docs:
            # Check for verbatim passages exceeding 10 words
            doc_sentences = self._extract_sentences(doc['text'])
            for sentence in doc_sentences:
                words = sentence.split()
                if len(words) > 10 and sentence in output:
                    violations.append({
                        'document': doc['filename'],
                        'verbatim_excerpt': sentence[:100] + '...',
                        'violation': 'Verbatim reproduction of >10 words from RESTRICTED document',
                        'legal_basis': 'Infopaq doctrine / InfoSoc Directive Art. 2'
                    })

        return {
            'compliant': len(violations) == 0,
            'violations': violations,
            'action': (
                'Remove verbatim excerpts and replace with paraphrased summaries'
                if violations else None
            )
        }
```

