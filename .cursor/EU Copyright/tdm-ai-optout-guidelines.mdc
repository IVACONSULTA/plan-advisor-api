## ðĪ Compliant TDM Checker Implementation

```python
# guardrails/copyright_checker.py
"""
EU Copyright Compliance Guardrail
References:
- DSM Directive (EU) 2019/790, Arts. 3 and 4 (TDM exception + opt-out)
- InfoSoc Directive 2001/29/EC, Art. 2 (reproduction right)
- EU AI Act (EU) 2024/1689, Art. 53(1)(c) (copyright compliance for AI)
"""
import re
from typing import List, Dict, Tuple

class CopyrightChecker:

    SCAN_CHARS = 3000  # Scan first 3000 chars (headers/preamble)

    def check_documents(
        self, documents: List[Dict]
    ) -> Tuple[bool, List[Dict]]:
        """
        Check all documents for TDM opt-out and reproduction restrictions.

        Returns:
            (all_clear: bool, results: list of per-document check results)
        """
        results = []
        all_clear = True

        for doc in documents:
            text_sample = doc.get('text', '')[:self.SCAN_CHARS]
            filename = doc.get('filename', 'unknown')

            ai_blocked, ai_reason = self._check_ai_optout(text_sample, filename)
            repro_restricted, repro_reason = self._check_reproduction_rights(
                text_sample, filename
            )

            if ai_blocked:
                all_clear = False
                results.append({
                    'filename': filename,
                    'status': 'blocked',  # ðŦ BLOCKED
                    'reason': ai_reason,
                    'restriction_type': 'ai_optout',
                    'legal_basis': 'DSM Directive Art. 4 opt-out / EU AI Act Art. 53(1)(c)',
                    'action': (
                        'Document must be reviewed manually by Admin. '
                        'AI processing not permitted.'
                    )
                })
            elif repro_restricted:
                results.append({
                    'filename': filename,
                    'status': 'restricted',  # ðĄ RESTRICTED
                    'reason': repro_reason,
                    'restriction_type': 'reproduction_rights',
                    'legal_basis': 'InfoSoc Directive 2001/29/EC, Art. 2',
                    'action': (
                        'Extract only factual rules. '
                        'source_excerpt must be paraphrased, not verbatim.'
                    )
                })
            else:
                results.append({
                    'filename': filename,
                    'status': 'clear',  # ðĒ CLEAR
                    'reason': 'No copyright restrictions detected.',
                    'action': 'Document may be processed. Cite source in extracted rules.'
                })

        return all_clear, results
```

